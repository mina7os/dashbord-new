# Required Environment Variables
# Copy this file to .env and fill in all values before running.

# ── Frontend Safe (VITE_ prefixed) ────────────────────────────────────────────
# These variables are exposed to the browser.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ── Server Only ───────────────────────────────────────────────────────────────
# These variables contain sensitive secrets. Never expose to the browser!
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Google AI Studio / Gemini API
GEMINI_API_KEY="your-gemini-api-key-here"

# Google OAuth2 (Google Sheets Integration)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Server Configuration
APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV="development"

# ── WhatsApp / Puppeteer Configuration ────────────────────────────────────────
WA_AUTH_TIMEOUT_MS=60000
WA_STARTUP_TIMEOUT_MS=120000
WA_QR_MAX_RETRIES=5
# Set to custom chromium path if needed (e.g., in Docker)
PUPPETEER_EXECUTABLE_PATH=""
